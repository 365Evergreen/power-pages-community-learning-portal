      },
      "userStories": [
        {
          "id": "us01",
          "description": "Create and publish workshop sessions so that learners can register and participate.",
          "userType": "Trainer"
        },
        {
          "id": "us02",
          "description": "Tailor workshop content to address specific community needs so that sessions are relevant and impactful.",
          "userType": "Trainer"
        },
        {
          "id": "us03",
          "description": "View participant enrollment lists so that I can prepare materials accordingly.",
          "userType": "Trainer"
        },
        {
          "id": "us04",
          "description": "Collect feedback from learners after sessions so that I can improve future workshops.",
          "userType": "Trainer"
        }
      ]
    },
    {
      "user": {
        "id": "Learner",
        "name": "Learner",
        "description": "Community member who enrolls in and attends workshops.",
