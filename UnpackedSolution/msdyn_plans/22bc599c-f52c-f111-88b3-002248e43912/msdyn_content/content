      },
      "userStories": [
        {
          "id": "us05",
          "description": "Browse available workshops so that I can find sessions that interest me.",
          "userType": "Learner"
        },
        {
          "id": "us06",
          "description": "Enroll in workshops so that I can develop new skills and knowledge.",
          "userType": "Learner"
        },
        {
          "id": "us07",
          "description": "Receive reminders and updates about sessions so that I stay informed.",
          "userType": "Learner"
        },
        {
          "id": "us08",
          "description": "Provide feedback about my learning experience so that programs can be improved.",
          "userType": "Learner"
        }
      ]
    },
    {
      "user": {
        "id": "Program coordinator",
        "name": "Program coordinator",
        "description": "Person who manages events, participant enrollment, and aligns programs with community needs.",
        "image": "https://content.powerapps.com/resource/makerx/static/media/PersonNote.bac78e19.svg"
      },
      "userStories": [
        {
          "id": "us09",
          "description": "Monitor enrollment numbers across workshops so that I can ensure sessions meet demand.",
          "userType": "Program coordinator"
        },
        {
          "id": "us10",
          "description": "Assign trainers to appropriate workshops so that sessions have qualified facilitators.",
          "userType": "Program coordinator"
        },
        {
          "id": "us11",
          "description": "Analyze feedback and participation data so that I can adjust program offerings to better serve the community.",
          "userType": "Program coordinator"
        },
        {
          "id": "us12",
          "description": "Send communications to trainers and learners so that everyone stays informed about program changes.",
          "userType": "Program coordinator"
        }
      ]
